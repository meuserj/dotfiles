{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#3c3836",
          "foreground": "#ebdbb2",
          "style": "powerline",
          "template": "{{ if .WSL }}WSL at{{ end }} {{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#504945",
          "foreground": "#EBDBB2",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " {{ if eq .Name \"zsh\" }}\uebc8{{ else if eq .Name \"bash\" }}\uebca{{ else if eq .Name \"fish\" }}\uf489{{ else if eq .Name \"pwsh\" }}\uebc7{{ else if eq .Name \"powershell\" }}\uebc7{{ else }}{{ .Name }}{{ end }} ",
          "type": "shell"
        },
        {
          "background": "#458588",
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "options": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " \ue0b5 ",
            "home_icon": "\ueb06",
            "style": "agnoster"
          },
          "style": "powerline",
          "template": "{{ if not (eq .Segments.Project.Name .Folder) }} {{ .Path }} {{ end }}",
          "type": "path"
        },
        {
          "type": "project",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "#282828",
          "background": "#d79921",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Version }} {{.Version}}{{ end }} {{ if .Name }}{{ .Name }}{{ end }}{{ end }} "
        },
        {
          "background": "#98971A",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fe8019{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#cc241d{{ end }}",
            "{{ if gt .Ahead 0 }}#d3869b{{ end }}",
            "{{ if gt .Behind 0 }}#d3869b{{ end }}"
          ],
          "foreground": "#282828",
          "leading_diamond": "\ue0b6",
          "powerline_symbol": "\ue0b4",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "branch_icon": "\uE0A0 ",
            "branch_identical_icon": "\u25CF"
          },
          "style": "powerline",
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "trailing_diamond": "\ue0b4",
          "type": "git"
        },
        {
          "background": "#83a598",
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "options": {
            "fetch_version": false
          },
          "style": "powerline",
          "template": " \ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "go"
        },
        {
          "background": "#458588",
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "options": {
            "fetch_version": false
          },
          "style": "powerline",
          "template": " \ue624 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "julia"
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "options": {
            "fetch_version": false
          },
          "foreground": "#282828",
          "background": "#98971a",
          "template": "  {{ .Full }} "
        },
        {
          "background": "#fabd2f",
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "options": {
            "display_mode": "files",
            "fetch_virtual_env": false,
            "fetch_version": false
          },
          "style": "powerline",
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "python"
        },
        {
          "background": "#cc241d",
          "foreground": "#ebdbb2",
          "powerline_symbol": "\ue0b4",
          "options": {
            "display_mode": "files",
            "fetch_version": false
          },
          "style": "powerline",
          "template": " \ue791 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "ruby"
        },
        {
          "background": "#fe8019",
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "options": {
            "display_mode": "files",
            "fetch_version": false
          },
          "style": "powerline",
          "template": " \uf0e7{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "azfunc"
        },
        {
          "background_templates": [
            "{{if contains \"default\" .Profile}}#d65d0e{{end}}",
            "{{if contains \"jan\" .Profile}}#fb4934{{end}}"
          ],
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "options": {
            "display_default": false
          },
          "style": "powerline",
          "template": " \ue7ad {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
          "type": "aws"
        },
        {
          "background": "#fabd2f",
          "foreground": "#282828",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " \uf0ad ",
          "type": "root"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "version": 4
}
